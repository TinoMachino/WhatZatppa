#!/bin/sh

# Find files being committed
FILES=$(git diff --cached --name-only)

# Check for merge conflict markers in all staged files
for FILE in $FILES; do
  if [ -f "$FILE" ]; then
    if grep -q -E '<{7} HEAD|={7}|>{7}' "$FILE"; then
      echo "❌ Error: Unresolved merge conflict marker found in: $FILE"
      echo "Please resolve the conflict, remove the markers, and add the file again."
      exit 1
    fi
  fi
done

