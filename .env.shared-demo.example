DEV_ENV_PERSISTENT=true
DEV_ENV_SKIP_MOCK_SETUP=true

# Stable public identities for the shared demo.
DEV_ENV_PDS_HOSTNAME=pds.paramx.social
DEV_ENV_BSKY_PUBLIC_URL=https://appview.paramx.social
DEV_ENV_ENABLE_DID_DOC_WITH_SESSION=false

# Persistent storage on the host machine running the demo backend.
DEV_ENV_STORAGE_ROOT=~/.paramx-demo
DEV_ENV_PDS_DATA_DIRECTORY=~/.paramx-demo/pds
DEV_ENV_PDS_BLOBSTORE_DIRECTORY=~/.paramx-demo/blobstore

# Postgres schemas for the shared demo.
DEV_ENV_PLC_DB_SCHEMA=plc_demo
DEV_ENV_BSKY_DB_SCHEMA=bsky_demo
DEV_ENV_OZONE_DB_SCHEMA=ozone_demo
